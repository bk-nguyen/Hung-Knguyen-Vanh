\frametitle{Bài 4 - Code}

\begin{lstlisting}
int main(){
    int n;
    cin>>n;

    vector<int> deg(n+1,0);

    for(int i=1;i<n;i++){
        int u,v;
        cin>>u>>v;
        deg[u]++;
        deg[v]++;
    }
    if(n==1){
        cout<<1;
        return 0;
    }
    int cnt=0;
    for(int i=1;i<=n;i++){
        if(deg[i]==1) cnt++;
    }

    cout<<cnt;
}
\end{lstlisting}

